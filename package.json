{
  "name": "ai-literacy-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "validate:prod-env": "node scripts/validate-prod-env.mjs",
    "check:auth0-config": "node scripts/check-auth0-config-alignment.mjs",
    "build": "npm run validate:prod-env && vite build",
    "backend": "cd backend && FLASK_DEBUG=0 PORT=${PORT:-5001} ${PYTHON_CMD:-venv/bin/python} app.py",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "e2e:install": "playwright install",
    "test:e2e": "playwright test",
    "test:e2e:record": "PLAYWRIGHT_RECORD_MODE=1 npm run test:e2e -- --headed --project=chromium",
    "e2e": "npm run test:e2e -- e2e/platform.spec.ts",
    "e2e:flow": "npm run test:e2e -- e2e/platform.spec.ts",
    "e2e:smoke": "npm run test:e2e -- e2e/platform-smoke.spec.ts",
    "e2e:headed": "npm run e2e:flow -- --headed"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.15.0",
    "@headlessui/react": "^1.7.17",
    "@supabase/supabase-js": "^2.74.0",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "stripe": "^19.1.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.3",
    "vite": "^4.5.0",
    "vitest": "^4.0.18"
  }
}
