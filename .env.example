# Frontend environment variables
# Local Flask fallback: http://localhost:5001
# Production Supabase Edge Function (do not use Supabase REST /rest/v1 here):
# https://<project-ref>.supabase.co/functions/v1/platform-api
VITE_API_URL=http://localhost:5001

# Supabase auth (required for release builds and protected backend routes)
VITE_AUTH_MODE=supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-supabase-publishable-key

# Local review helper only. Keep disabled in deployed environments.
VITE_SUPABASE_AUTH_STUB=0
VITE_DEMO_REVIEW_EMAIL=reviewer@example.com
VITE_DEMO_REVIEW_FIRST_NAME=Review
VITE_DEMO_REVIEW_LAST_NAME=User
ENABLE_DEMO_AUTH=0

# Supabase Edge Function secrets
# Set these with `supabase secrets set ...`; do not expose them to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Server-side assessment generation
# Used by Flask fallback and Supabase Edge Function. Never prefix these with VITE_.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ASSESSMENT_QUESTION_SET_SECRET=replace-with-a-long-random-secret

# Stripe secrets for Supabase Edge Function billing routes
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_PREMIUM=price_live_or_test_premium
STRIPE_PRICE_ENTERPRISE=price_live_or_test_enterprise

# Legacy Flask fallback only
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
DATABASE_URL=sqlite:///ai_literacy.db
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001
SUPABASE_JWT_AUDIENCE=authenticated
