# Backend Environment Variables
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# DATABASE_URL options:
# sqlite:///ai_literacy.db                  (local development)
# postgresql://user:password@host:5432/db  (production on Neon/Render/Railway/Supabase Postgres/etc.)
DATABASE_URL=sqlite:///ai_literacy.db

# Optional: For production deployment
FLASK_ENV=development
FLASK_DEBUG=True

# Optional: Stripe integration (for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Frontend Environment Variables
VITE_API_URL=http://localhost:5001

# Auth mode: auto (default, Supabase-first; falls back to backend when Supabase vars are absent),
# backend (force backend email/password auth),
# supabase (force Supabase),
# auth0 (force Auth0 Universal Login)
VITE_AUTH_MODE=auto

# Supabase settings (social login + Supabase sessions)
# Required when VITE_AUTH_MODE is auto or supabase.
# Optional in backend or auth0 mode unless you intentionally keep OAuth in hybrid setups.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for Supabase-backed token verification.
# Optional in auth0 mode if JWT_SECRET_KEY is available in backend runtime.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Backend token signing fallback used by /api/auth/exchange.
JWT_SECRET_KEY=your-jwt-secret-key-here

# Auth0 settings (required when VITE_AUTH_MODE=auth0)
VITE_AUTH0_DOMAIN=https://your-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=your-auth0-audience
VITE_AUTH0_REDIRECT_URI=https://your-site.com/auth/callback

# Auth0 runtime settings for backend token verification in /api/auth/exchange.
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_AUDIENCE=your-auth0-audience