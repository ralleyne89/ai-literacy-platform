# Backend Environment Variables
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# DATABASE_URL options:
# sqlite:///ai_literacy.db                  (local development)
# postgresql://user:password@host:5432/db  (production on Neon/Render/Railway/Supabase Postgres/etc.)
DATABASE_URL=sqlite:///ai_literacy.db

# Optional: For production deployment
FLASK_ENV=development
FLASK_DEBUG=True

# Optional: Stripe integration (for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Frontend Environment Variables
# Point this at your public backend API.
# Local: http://localhost:5001
# Production: https://ai-literacy-platform.onrender.com
VITE_API_URL=http://localhost:5001

# Supported in production: auth0 | backend | supabase.
# `auto` is disabled in production and treated as invalid.
VITE_AUTH_MODE=auth0

# Supabase settings (used only in supabase mode)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for Supabase-backed token verification.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Backend token signing/verification used by backend and Auth0 exchange modes.
JWT_SECRET_KEY=your-jwt-secret-key-here

# Auth0 settings (required when VITE_AUTH_MODE=auth0)
VITE_AUTH0_DOMAIN=https://your-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=your-auth0-audience
VITE_AUTH0_REDIRECT_URI=https://your-site.com/auth/callback

# Auth0 runtime settings for backend token verification in /api/auth/exchange.
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_REDIRECT_URI=https://litmusai.netlify.app/auth/callback
