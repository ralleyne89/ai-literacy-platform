# Backend Environment Variables
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# DATABASE_URL options:
# sqlite:///ai_literacy.db                  (local development)
# postgresql://user:password@host:5432/db  (production on Neon/Render/Railway/Supabase Postgres/etc.)
DATABASE_URL=sqlite:///ai_literacy.db

# Optional: For production deployment
FLASK_ENV=development
FLASK_DEBUG=True

# Optional: Stripe integration (for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
FRONTEND_URL=http://localhost:5173

# Frontend Environment Variables
VITE_API_URL=http://localhost:5001

# Optional: force backend auth mode (use /api/auth/login and /api/auth/register)
VITE_AUTH_MODE=backend

# Supabase auth for social providers (required for Google/Facebook OAuth)
# Keep these set even in backend mode if you want provider login.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
