# Backend Environment Variables
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# DATABASE_URL options:
# sqlite:///ai_literacy.db                  (local development)
# postgresql://user:password@host:5432/db  (production on Neon/Render/Railway/Postgres providers/etc.)
DATABASE_URL=sqlite:///ai_literacy.db

# Optional: For production deployment
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# Optional: Stripe integration (for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PREMIUM=price_live_or_test_premium
STRIPE_PRICE_ENTERPRISE=price_live_or_test_enterprise
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Optional explicit backend URL for Netlify billing/webhook proxy functions.
# Defaults to VITE_API_URL when omitted.
BACKEND_API_URL=http://localhost:5001

# Frontend Environment Variables
# Point this at your public backend API.
# Local: http://localhost:5001
# Production: https://ai-literacy-platform.onrender.com
VITE_API_URL=http://localhost:5001

# Clerk auth (required for release builds and protected backend routes)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_JWT_ISSUER=https://your-clerk-issuer
CLERK_JWKS_URL=https://your-clerk-issuer/.well-known/jwks.json
