# Legacy Flask backend environment variables (local fallback only).
# The production API target is Supabase Edge Functions.

SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
DATABASE_URL=sqlite:///ai_literacy.db
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5001

# Stripe keys for local Flask fallback. In production, set these as Supabase
# Edge Function secrets with `supabase secrets set`.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase auth for local Flask fallback
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
# Prefer Supabase JWKS/signing keys. Keep SUPABASE_JWT_SECRET only for legacy HS256 projects.
SUPABASE_JWT_SECRET=your-legacy-supabase-jwt-secret-if-needed

# Frontend URL
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
