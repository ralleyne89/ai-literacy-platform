# Backend Environment Variables (for local development only)
# Copy this file to .env and fill in your actual values

SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
DATABASE_URL=sqlite:///ai_literacy.db
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5001

# Stripe Keys (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# JWT signing for Flask-issued session tokens used by /api/auth/exchange.
# Set exactly one of these for production; JWT_SECRET_KEY is also accepted as fallback.
JWT_SECRET_KEY=your-jwt-secret-here
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Auth0 (required for auth0 token exchange)
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=your-auth0-audience

# Frontend URL
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173


